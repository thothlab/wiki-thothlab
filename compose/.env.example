# Скопируйте этот файл в .env и заполните секреты.
# Файл .env в git не коммитится.

# Postgres
POSTGRES_DB=wiki
POSTGRES_USER=wikijs
POSTGRES_PASSWORD=CHANGE_ME_STRONG_RANDOM

# Wiki.js — публикуется ТОЛЬКО на 127.0.0.1 (наружу — через SSH-туннель + Caddy на VPS).
# Свободный порт на Mac Mini: 3010 (3001 занят Gitea).
WIKI_HOST_PORT=3010

# Часовой пояс контейнеров
TZ=Europe/Moscow
